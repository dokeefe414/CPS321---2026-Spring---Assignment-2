int sys_write(unsigned int fd, char *buf, int count) {
    struct file *file;

    // Check file descriptor range
    // Prevent invalid access by ensuring fd is within allowed limits
    if (fd >= NR_OPEN)
        return -EINVAL;

    // Get file structure
    // Maps file descriptor (fd) to the corresponding kernel file object
    file = current->filp[fd];

    // Check if file exists
    // Ensure the file descriptor is valid and currently open
    if (!file)
        return -EINVAL;

    // Handle empty write
    // If count is 0, nothing needs to be written, so return immediately
    if (!count)
        return 0;

    // Call device-specific write function
    // Delegates the actual writing to the file/tty driver associated with the file
    // (Actual device writing happens here — not required for this explanation)
    return file->f_op->write(file, buf, count);
}
